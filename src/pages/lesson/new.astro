---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Compute next Sunday as default date
function getNextSunday(): string {
  const now = new Date();
  const day = now.getDay();
  const daysUntilSunday = day === 0 ? 7 : 7 - day;
  const nextSunday = new Date(now);
  nextSunday.setDate(now.getDate() + daysUntilSunday);
  return nextSunday.toISOString().split('T')[0];
}

const defaultDate = getNextSunday();
---
<BaseLayout title="New Lesson — Prepare">
  <div class="min-h-[100dvh] flex flex-col">
    <!-- Header -->
    <header class="sticky top-0 z-10 bg-white border-b border-gray-200 px-4 py-3">
      <div class="flex items-center gap-3">
        <a href="/" class="text-blue-600 text-2xl leading-none min-w-[44px] min-h-[44px] flex items-center justify-center -ml-2">&larr;</a>
        <h1 class="text-lg font-semibold">New Lesson</h1>
      </div>
    </header>

    <main class="flex-1 px-4 py-6">
      <form id="new-lesson-form" class="space-y-5">
        <div>
          <label for="topic" class="block text-sm font-medium text-gray-700 mb-1.5">Topic</label>
          <input
            type="text"
            id="topic"
            name="topic"
            required
            placeholder="e.g., Faith as a seed — Alma 32"
            class="w-full rounded-lg border border-gray-300 px-3 py-3 text-base placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          />
        </div>

        <div>
          <label for="date" class="block text-sm font-medium text-gray-700 mb-1.5">Lesson Date</label>
          <input
            type="date"
            id="date"
            name="date"
            value={defaultDate}
            required
            class="w-full rounded-lg border border-gray-300 px-3 py-3 text-base focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          />
        </div>

        <div>
          <label for="audience" class="block text-sm font-medium text-gray-700 mb-1.5">Audience</label>
          <input
            type="text"
            id="audience"
            name="audience"
            value="Elders Quorum"
            placeholder="e.g., Elders Quorum"
            class="w-full rounded-lg border border-gray-300 px-3 py-3 text-base placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          />
        </div>

        <button
          type="submit"
          class="w-full bg-blue-600 text-white font-medium text-base py-3.5 rounded-lg active:bg-blue-700 min-h-[44px]"
        >
          Create Lesson
        </button>
      </form>
    </main>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('new-lesson-form') as HTMLFormElement;
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const topic = (document.getElementById('topic') as HTMLInputElement).value.trim();
    const date = (document.getElementById('date') as HTMLInputElement).value;
    const audience = (document.getElementById('audience') as HTMLInputElement).value.trim() || 'Elders Quorum';

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Creating...';

    try {
      const res = await fetch('/api/lessons', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ topic, date, audience }),
      });
      const { slug } = await res.json();
      window.location.href = `/lesson/${slug}`;
    } catch (err) {
      btn.disabled = false;
      btn.textContent = 'Create Lesson';
      alert('Failed to create lesson. Please try again.');
    }
  });
</script>
